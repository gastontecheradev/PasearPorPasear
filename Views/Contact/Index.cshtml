@model ContactMessage
@{
    ViewData["Title"] = "Contacto";
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    var isEn = requestCulture?.RequestCulture?.Culture?.TwoLetterISOLanguageName == "en";
    var isPt = requestCulture?.RequestCulture?.Culture?.TwoLetterISOLanguageName == "pt";
    var mailchimpUrl = ViewBag.MailchimpFormUrl as string;
}

<section class="section">
    <div class="container">
        <div class="section-header reveal">
            <span class="section-label">@(isPt ? "Contato" : isEn ? "Contact" : "Contacto")</span>
            <h2 class="section-title">@(isPt ? "Entre em Contato" : isEn ? "Get in Touch" : "Ponete en Contacto")</h2>
            <p class="section-subtitle">@(isEn ? "Have questions about a tour, the walking club, or just want to chat about Montevideo? Write to us!" : "¿Tenés preguntas sobre un tour, el club de paseo, o simplemente querés charlar sobre Montevideo? ¡Escribinos!")</p>
        </div>

        <div class="contact-layout" style="display:flex;justify-content:center;">
            <div class="reveal" style="width:100%;max-width:560px;margin:0 auto;">
                <form asp-controller="Contact" asp-action="Index" method="post">
                    <div class="form-group">
                        <label>@(isPt ? "Nome" : isEn ? "Name" : "Nombre") *</label>
                        <input asp-for="Name" class="form-control" placeholder="@(isEn ? "Your name" : "Tu nombre")">
                        <span asp-validation-for="Name" style="color:var(--danger);font-size:var(--fs-xs)"></span>
                    </div>
                    <div class="form-group">
                        <label>Email *</label>
                        <input asp-for="Email" class="form-control" placeholder="@(isEn ? "your@email.com" : "tu@email.com")">
                        <span asp-validation-for="Email" style="color:var(--danger);font-size:var(--fs-xs)"></span>
                    </div>
                    <div class="form-group">
                        <label>@(isPt ? "Assunto" : isEn ? "Subject" : "Asunto")</label>
                        <input asp-for="Subject" class="form-control" placeholder="@(isPt ? "Assunto" : isEn ? "Subject" : "Asunto")">
                    </div>
                    <div class="form-group">
                        <label>@(isPt ? "Mensagem" : isEn ? "Message" : "Mensaje") *</label>
                        <textarea asp-for="Message" class="form-control" rows="5" placeholder="@(isEn ? "Your message..." : "Tu mensaje...")"></textarea>
                        <span asp-validation-for="Message" style="color:var(--danger);font-size:var(--fs-xs)"></span>
                    </div>
                    <button type="submit" class="btn btn-yellow">
                        @(isPt ? "Enviar Mensagem" : isEn ? "Send Message" : "Enviar Mensaje")
                        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14" /><path d="m12 5 7 7-7 7" /></svg>
                    </button>
                </form>
            </div>



            @* <div class="reveal">
                <div class="contact-info-item">
                    <div class="contact-icon">📧</div>
                    <div>
                        <div style="font-weight:600;font-size:var(--fs-sm)">Email</div>
                        <div style="color:var(--ink-60);font-size:var(--fs-sm)">pasearporpasear@@gmail.com</div>
                    </div>
                </div>
                <div class="contact-info-item">
                    <div class="contact-icon">📍</div>
                    <div>
                        <div style="font-weight:600;font-size:var(--fs-sm)">@(isPt ? "Localização" : isEn ? "Location" : "Ubicación")</div>
                        <div style="color:var(--ink-60);font-size:var(--fs-sm)">Montevideo, Uruguay</div>
                    </div>
                </div>
                <div class="contact-info-item">
                    <div class="contact-icon">📱</div>
                    <div>
                        <div style="font-weight:600;font-size:var(--fs-sm)">@(isPt ? "Redes Sociais" : isEn ? "Social Media" : "Redes Sociales")</div>
                        <div style="color:var(--ink-60);font-size:var(--fs-sm)">@@pasearporpasear</div>
                    </div>
                </div> *@

            @* <div style="margin-top:32px;padding:28px;background:var(--yellow-light);border-radius:var(--radius-lg)">
                    <h4 style="font-family:var(--font-display);margin-bottom:8px">@(isPt ? "Resposta Rápida" : isEn ? "Quick Response" : "Respuesta Rápida")</h4>
                    <p style="font-size:var(--fs-sm);color:var(--ink-60);line-height:1.7">@(isEn ? "We usually respond within 24 hours. For tour reservations, we'll confirm availability by email." : "Generalmente respondemos dentro de las 24 horas. Para reservas de tours, confirmamos disponibilidad por email.")</p>
                </div> *@
        </div>
    </div>
</section>

<section class="section">
    <div class="container" style="max-width:560px">
        <div class="section-header reveal">
            <span class="section-label">Newsletter</span>
            <h2 class="section-title">@(isPt ? "Fique por Dentro" : isEn ? "Stay in the Loop" : "Mantenete al Día")</h2>
            <p class="section-subtitle">@(isPt ? "Receba itinerários, novas publicações, datas do clube de passeio e recomendações exclusivas diretamente no seu e-mail." : isEn ? "Receive itineraries, new posts, walking club dates, and exclusive recommendations directly in your inbox." : "Recibí itinerarios, nuevas publicaciones, fechas del club de paseo y recomendaciones exclusivas directo en tu correo.")</p>
        </div>

        @if (!string.IsNullOrEmpty(mailchimpUrl))
        {
            <!-- Mailchimp Embedded Form -->
            <div class="mailchimp-embed reveal">
                <iframe src="@mailchimpUrl" frameborder="0" scrolling="no" style="width:100%;min-height:400px;border:none;border-radius:var(--radius-lg)"></iframe>
            </div>
        }
        else
        {
            <!-- Local subscription form (fallback) -->
            <div class="reveal" style="background:var(--bg-card);border:1px solid var(--ink-10);border-radius:var(--radius-lg);padding:40px">
                <form asp-controller="Newsletter" asp-action="Subscribe" method="post">
                    <div class="form-group">
                        <label>@(isPt ? "Seu Nome" : isEn ? "Your Name" : "Tu Nombre")</label>
                        <input type="text" name="name" class="form-control" placeholder="@(isEn ? "Name (optional)" : "Nombre (opcional)")">
                    </div>
                    <div class="form-group">
                        <label>Email *</label>
                        <input type="email" name="email" class="form-control" placeholder="@(isEn ? "your@email.com" : "tu@email.com")" required>
                    </div>
                    <button type="submit" class="btn btn-yellow" style="width:100%;justify-content:center">
                        @(isPt ? "Inscrever-me" : isEn ? "Subscribe" : "Suscribirme")
                    </button>
                    <p class="form-hint" style="text-align:center;margin-top:12px">
                        @(isEn ? "We respect your privacy. Unsubscribe at any time." : "Respetamos tu privacidad. Podés darte de baja en cualquier momento.")
                    </p>
                </form>
            </div>
        }

        @* <div style="margin-top:56px;text-align:center" class="reveal">
            <h3 style="font-family:var(--font-display);margin-bottom:12px">@(isPt ? "O que você vai receber" : isEn ? "What you'll receive" : "Qué vas a recibir")</h3>
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:20px;margin-top:24px">
                <div style="padding:24px;background:var(--yellow-light);border-radius:var(--radius-lg);text-align:center">
                    <div style="font-size:2rem;margin-bottom:8px">📝</div>
                    <div style="font-weight:600;font-size:var(--fs-sm)">@(isPt ? "Novas Publicações" : isEn ? "New Posts" : "Nuevas Publicaciones")</div>
                </div>
                <div style="padding:24px;background:var(--yellow-light);border-radius:var(--radius-lg);text-align:center">
                    <div style="font-size:2rem;margin-bottom:8px">🗺️</div>
                    <div style="font-weight:600;font-size:var(--fs-sm)">@(isPt ? "Roteiros" : isEn ? "Routes" : "Recorridos")</div>
                </div>
                <div style="padding:24px;background:var(--yellow-light);border-radius:var(--radius-lg);text-align:center">
                    <div style="font-size:2rem;margin-bottom:8px">👥</div>
                    <div style="font-weight:600;font-size:var(--fs-sm)">@(isPt ? "Datas do Clube" : isEn ? "Club Dates" : "Fechas del Club")</div>
                </div>
            </div>
        </div> *@
    </div>
</section>