@model ContactMessage
@{
    ViewData["Title"] = "Contacto";
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    var isEn = requestCulture?.RequestCulture?.Culture?.TwoLetterISOLanguageName == "en";
    var isPt = requestCulture?.RequestCulture?.Culture?.TwoLetterISOLanguageName == "pt";
    var mailchimpUrl = ViewBag.MailchimpFormUrl as string;
}

<section class="section">
    <div class="container">
        <div class="section-header reveal">
            <span class="section-label">@(isPt ? "Contato" : isEn ? "Contact" : "Contacto")</span>
            <h2 class="section-title">@(isPt ? "Entre em Contato" : isEn ? "Get in Touch" : "Ponete en Contacto")</h2>
            <p class="section-subtitle">@(isEn ? "Have questions about a tour, the walking club, or just want to chat about Montevideo? Write to us!" : "¿Tenés preguntas sobre un tour, el club de paseo, o simplemente querés charlar sobre Montevideo? ¡Escribinos!")</p>
        </div>

        <div class="contact-newsletter-row">
            <!-- Contact Form -->
            <div class="contact-newsletter-col reveal">
                <h3 class="contact-col-heading">@(isPt ? "Envie uma Mensagem" : isEn ? "Send a Message" : "Enviá un Mensaje")</h3>
                <p style="color:var(--ink-60);font-size:var(--fs-sm);margin-bottom:24px">@(isPt ? "Envie-nos sua mensagem." : isEn ? "Send us your message." : " Escribinos tu mensaje.")</p>
                <form asp-controller="Contact" asp-action="Index" method="post">
                    <div class="form-group">
                        <label>@(isPt ? "Nome" : isEn ? "Name" : "Nombre") *</label>
                        <input asp-for="Name" class="form-control" placeholder="@(isEn ? "Your name" : "Tu nombre")">
                        <span asp-validation-for="Name" style="color:var(--danger);font-size:var(--fs-xs)"></span>
                    </div>
                    <div class="form-group">
                        <label>Email *</label>
                        <input asp-for="Email" class="form-control" placeholder="@(isEn ? "your@email.com" : "tu@email.com")">
                        <span asp-validation-for="Email" style="color:var(--danger);font-size:var(--fs-xs)"></span>
                    </div>
                    <div class="form-group">
                        <label>@(isPt ? "Assunto" : isEn ? "Subject" : "Asunto")</label>
                        <input asp-for="Subject" class="form-control" placeholder="@(isPt ? "Assunto" : isEn ? "Subject" : "Asunto")">
                    </div>
                    <div class="form-group">
                        <label>@(isPt ? "Mensagem" : isEn ? "Message" : "Mensaje") *</label>
                        <textarea asp-for="Message" class="form-control" rows="5" placeholder="@(isEn ? "Your message..." : "Tu mensaje...")"></textarea>
                        <span asp-validation-for="Message" style="color:var(--danger);font-size:var(--fs-xs)"></span>
                    </div>
                    <button type="submit" class="btn btn-yellow">
                        @(isPt ? "Enviar Mensagem" : isEn ? "Send Message" : "Enviar Mensaje")
                        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14" /><path d="m12 5 7 7-7 7" /></svg>
                    </button>
                </form>
            </div>

            <!-- Newsletter Form -->
            <div class="contact-newsletter-col reveal">
                <h3 class="contact-col-heading">Newsletter</h3>
                <p style="color:var(--ink-60);font-size:var(--fs-sm);margin-bottom:24px">@(isPt ? "Receba itinerários, novas publicações, datas do clube de passeio e recomendações exclusivas diretamente no seu e-mail." : isEn ? "Receive itineraries, new posts, walking club dates, and exclusive recommendations directly in your inbox." : "Recibí itinerarios, nuevas publicaciones, fechas del club de paseo y recomendaciones exclusivas directo en tu correo.")</p>

                @if (!string.IsNullOrEmpty(mailchimpUrl))
                {
                    <div class="mailchimp-embed">
                        <iframe src="@mailchimpUrl" frameborder="0" scrolling="no" style="width:100%;min-height:400px;border:none;border-radius:var(--radius-lg)"></iframe>
                    </div>
                }
                else
                {
                    <div style="background:var(--bg-card);border:1px solid var(--ink-10);border-radius:var(--radius-lg);padding:32px">
                        <form asp-controller="Newsletter" asp-action="Subscribe" method="post">
                            <div class="form-group">
                                <label>@(isPt ? "Seu Nome" : isEn ? "Your Name" : "Tu Nombre")</label>
                                <input type="text" name="name" class="form-control" placeholder="@(isEn ? "Name (optional)" : "Nombre (opcional)")">
                            </div>
                            <div class="form-group">
                                <label>Email *</label>
                                <input type="email" name="email" class="form-control" placeholder="@(isEn ? "your@email.com" : "tu@email.com")" required>
                            </div>
                            <button type="submit" class="btn btn-yellow" style="width:100%;justify-content:center">
                                @(isPt ? "Inscrever-me" : isEn ? "Subscribe" : "Suscribirme")
                            </button>
                            <p class="form-hint" style="text-align:center;margin-top:12px">
                                @(isEn ? "We respect your privacy. Unsubscribe at any time." : "Respetamos tu privacidad. Podés darte de baja en cualquier momento.")
                            </p>
                        </form>
                    </div>
                }
            </div>
        </div>
    </div>
</section>
