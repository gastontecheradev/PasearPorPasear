@model ClubDePaseoEntry
@{
    ViewData["Title"] = Model.Title;
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    var isEn = requestCulture?.RequestCulture?.Culture?.TwoLetterISOLanguageName == "en";
    var isPt = requestCulture?.RequestCulture?.Culture?.TwoLetterISOLanguageName == "pt";
}

<section class="content-page">
    <div class="container">
        @if (User.IsInRole("Admin"))
        {
            <div class="admin-edit-bar">
                <a href="/ClubDePaseo/Edit/@Model.Id" class="btn btn-yellow btn-sm">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                    @(isPt ? "Editar publicação" : isEn ? "Edit post" : "Editar publicación")
                </a>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.ImagePath))
        {
            <img src="@Model.ImagePath" alt="@(isPt ? Model.TitlePt : isEn ? Model.TitleEn : Model.Title)" class="content-hero-img">
        }

        <div class="content-meta">
            <span>@Model.PublishDate.ToString("dd MMMM yyyy")</span>
            @{
                var locName = isPt ? Model.LocationNamePt : isEn ? Model.LocationNameEn : Model.LocationName;
            }
            @if (!string.IsNullOrEmpty(locName))
            {
                <span>📍 @locName</span>
            }
        </div>

        <h1 class="content-title">@(isPt ? Model.TitlePt : isEn ? Model.TitleEn : Model.Title)</h1>

        <div class="content-body">
            @Html.Raw(isPt ? Model?.ContentPt : isEn ? Model?.ContentEn : Model?.Content)
        </div>

        @if (!string.IsNullOrEmpty(Model.MapEmbedUrl))
        {
            <iframe src="@Model.MapEmbedUrl" class="content-map" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
        }

        <div style="margin-top:48px;padding-top:32px;border-top:1px solid var(--ink-10)">
            <a href="/ClubDePaseo" class="btn btn-outline">← @(isPt ? "Voltar ao Clube" : isEn ? "Back to Club" : "Volver al Club")</a>
        </div>
    </div>
</section>
