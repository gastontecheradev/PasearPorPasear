@model List<Itinerary>
@{
    ViewData["Title"] = "Gestionar Itinerarios";
    ViewData["AdminTitle"] = "Gestionar Itinerarios";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px">
    <h3 style="font-family:var(--font-display)">@Model.Count itinerarios</h3>
    <a href="/Itineraries/Create" class="btn btn-teal btn-sm">+ Nuevo Itinerario</a>
</div>

<table class="admin-table">
    <thead>
        <tr>
            <th>Título</th>
            <th>Duración</th>
            <th>Distancia</th>
            <th>Estado</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td><strong>@item.Title</strong></td>
                <td>@item.Duration</td>
                <td>@item.Distance</td>
                <td><span class="badge @(item.IsPublished ? "badge-confirmed" : "badge-pending")">@(item.IsPublished ? "Publicado" : "Borrador")</span></td>
                <td>
                    <div style="display:flex;gap:6px">
                        <a href="/Itineraries/Detail/@item.Slug" class="btn btn-outline btn-xs" target="_blank">Ver</a>
                        <a href="/Itineraries/Edit/@item.Id" class="btn btn-outline btn-xs">Editar</a>
                        <form asp-controller="Itineraries" asp-action="Delete" method="post" id="del-itin-@item.Id" style="display:inline">
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="button" onclick="confirmDelete('del-itin-@item.Id','¿Eliminar este itinerario?')" class="btn btn-danger btn-xs">Eliminar</button>
                        </form>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>
