@model ClubDePaseoEntry
@{
    ViewData["Title"] = Model.Title;
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    var isEn = requestCulture?.RequestCulture?.Culture?.TwoLetterISOLanguageName == "en";
    var isPt = requestCulture?.RequestCulture?.Culture?.TwoLetterISOLanguageName == "pt";
}

<section class="content-page">
    <div class="container">
        @if (!string.IsNullOrEmpty(Model.ImagePath))
        {
            <img src="@Model.ImagePath" alt="@(isPt ? Model.TitlePt : isEn ? Model.TitleEn : Model.Title)" class="content-hero-img">
        }

        <div class="content-meta">
            @if (!string.IsNullOrEmpty(Model.Duration))
            {
                <span>⏱ @(isPt ? Model.DurationPt : isEn ? Model.DurationEn : Model.Duration)</span>
            }
            @if (!string.IsNullOrEmpty(Model.Distance))
            {
                <span>📏 @Model.Distance</span>
            }
        </div>

        <h1 class="content-title">@(isPt ? Model.TitlePt : isEn ? Model.TitleEn : Model.Title)</h1>
        <p style="font-size:var(--fs-md);color:var(--ink-60);margin-bottom:28px;line-height:1.8">@(isPt ? Model.DescriptionPt : isEn ? Model.DescriptionEn : Model.Description)</p>

        <div class="content-body">
            @Html.Raw(isPt ? Model.ContentPt : isEn ? Model.ContentEn : Model.Content)
        </div>

        @if (!string.IsNullOrEmpty(Model.MapEmbedUrl))
        {
            <iframe src="@Model.MapEmbedUrl" class="content-map" allowfullscreen="" loading="lazy"></iframe>
        }

        <div style="margin-top:44px;padding-top:28px;border-top:1px solid var(--ink-10)">
            <a href="/ClubDePaseo" class="btn btn-outline">← @(isPt ? "Voltar ao Clube" : isEn ? "Back to Club" : "Volver al Club")</a>
        </div>
    </div>
</section>
