@{
    ViewData["Title"] = "Newsletter";
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    var isEn = requestCulture?.RequestCulture?.Culture?.TwoLetterISOLanguageName == "en";
    var isPt = requestCulture?.RequestCulture?.Culture?.TwoLetterISOLanguageName == "pt";
    var mailchimpUrl = ViewBag.MailchimpFormUrl as string;
}

<section class="section">
    <div class="container" style="max-width:700px">
        <div class="section-header reveal">
            <span class="section-label">Newsletter</span>
            <h2 class="section-title">@(isPt ? "Fique por Dentro" : isEn ? "Stay in the Loop" : "Mantenete al Día")</h2>
            <p class="section-subtitle">@(isEn ? "Receive itineraries, new posts, walking club dates, and exclusive recommendations directly in your inbox." : "Recibí itinerarios, nuevas publicaciones, fechas del club de paseo y recomendaciones exclusivas directo en tu correo.")</p>
        </div>

        @if (!string.IsNullOrEmpty(mailchimpUrl))
        {
            <!-- Mailchimp Embedded Form -->
            <div class="mailchimp-embed reveal">
                <iframe src="@mailchimpUrl" frameborder="0" scrolling="no" style="width:100%;min-height:400px;border:none;border-radius:var(--radius-lg)"></iframe>
            </div>
        }
        else
        {
            <!-- Local subscription form (fallback) -->
            <div class="reveal" style="background:var(--bg-card);border:1px solid var(--ink-10);border-radius:var(--radius-lg);padding:40px">
                <form asp-controller="Newsletter" asp-action="Subscribe" method="post">
                    <div class="form-group">
                        <label>@(isPt ? "Seu Nome" : isEn ? "Your Name" : "Tu Nombre")</label>
                        <input type="text" name="name" class="form-control" placeholder="@(isEn ? "Name (optional)" : "Nombre (opcional)")">
                    </div>
                    <div class="form-group">
                        <label>Email *</label>
                        <input type="email" name="email" class="form-control" placeholder="@(isEn ? "your@email.com" : "tu@email.com")" required>
                    </div>
                    <button type="submit" class="btn btn-yellow" style="width:100%;justify-content:center">
                        @(isPt ? "Inscrever-me" : isEn ? "Subscribe" : "Suscribirme")
                    </button>
                    <p class="form-hint" style="text-align:center;margin-top:12px">
                        @(isEn ? "We respect your privacy. Unsubscribe at any time." : "Respetamos tu privacidad. Podés darte de baja en cualquier momento.")
                    </p>
                </form>
            </div>
        }

        <div style="margin-top:56px;text-align:center" class="reveal">
            <h3 style="font-family:var(--font-display);margin-bottom:12px">@(isPt ? "O que você vai receber" : isEn ? "What you'll receive" : "Qué vas a recibir")</h3>
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:20px;margin-top:24px">
                <div style="padding:24px;background:var(--yellow-light);border-radius:var(--radius-lg);text-align:center">
                    <div style="font-size:2rem;margin-bottom:8px">📝</div>
                    <div style="font-weight:600;font-size:var(--fs-sm)">@(isPt ? "Novas Publicações" : isEn ? "New Posts" : "Nuevas Publicaciones")</div>
                </div>
                <div style="padding:24px;background:var(--yellow-light);border-radius:var(--radius-lg);text-align:center">
                    <div style="font-size:2rem;margin-bottom:8px">🗺️</div>
                    <div style="font-weight:600;font-size:var(--fs-sm)">@(isPt ? "Roteiros" : isEn ? "Routes" : "Recorridos")</div>
                </div>
                <div style="padding:24px;background:var(--yellow-light);border-radius:var(--radius-lg);text-align:center">
                    <div style="font-size:2rem;margin-bottom:8px">👥</div>
                    <div style="font-weight:600;font-size:var(--fs-sm)">@(isPt ? "Datas do Clube" : isEn ? "Club Dates" : "Fechas del Club")</div>
                </div>
            </div>
        </div>
    </div>
</section>
