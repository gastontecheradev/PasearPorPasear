@model List<ClubDePaseoEntry>
@{
    ViewData["Title"] = "Club de Paseo";
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    var isEn = requestCulture?.RequestCulture?.Culture?.TwoLetterISOLanguageName == "en";
    var isPt = requestCulture?.RequestCulture?.Culture?.TwoLetterISOLanguageName == "pt";
    var clubPage = ViewBag.Page as ClubDePaseoPage;
    var currentPage = (int)(ViewBag.CurrentPage ?? 1);
    var totalPages = (int)(ViewBag.TotalPages ?? 1);
    var currentCategory = ViewBag.CurrentCategory as string;
}

<!-- Page Intro -->
<section class="content-page" style="padding-bottom:0">
    <div class="container" style="max-width:900px">
        @if (!string.IsNullOrEmpty(clubPage?.ImagePath))
        {
            <img src="@clubPage.ImagePath" alt="@(isPt ? clubPage?.TitlePt : isEn ? clubPage?.TitleEn : clubPage?.Title)" class="content-hero-img">
        }
        <div class="section-header" style="text-align:center">
            <span class="section-label">@(isPt ? "Clube de Caminhada" : isEn ? "Walking Club" : "Club de Paseo")</span>
            <h1 class="section-title">@(isPt ? clubPage?.TitlePt : isEn ? clubPage?.TitleEn : clubPage?.Title)</h1>
        </div>
        <div class="content-body" style="max-width:700px;margin:0 auto">
            @Html.Raw(isPt ? clubPage?.ContentPt : isEn ? clubPage?.ContentEn : clubPage?.Content)
        </div>

        @if (User.IsInRole("Admin"))
        {
            <div style="text-align:center;margin-top:24px">
                <a href="/ClubDePaseo/EditPage" class="btn btn-outline btn-sm">✏️ @(isPt ? "Editar Página" : isEn ? "Edit Page" : "Editar Página")</a>
            </div>
        }
    </div>
</section>

<!-- Entries (mismo formato que Blog) -->
<section class="section">
    <div class="container">
        <!-- Category Filter Tabs -->
        <div class="blog-category-tabs reveal">
            <a href="/ClubDePaseo" class="category-tab @(string.IsNullOrEmpty(currentCategory) ? "active" : "")">@(isPt ? "Todos" : isEn ? "All" : "Todos")</a>
            <a href="/ClubDePaseo?category=itinerarios" class="category-tab @(currentCategory == "itinerarios" ? "active" : "")">@(isPt ? "Itinerários" : isEn ? "Itineraries" : "Itinerarios")</a>
            <a href="/ClubDePaseo?category=personal" class="category-tab @(currentCategory == "personal" ? "active" : "")">Personal</a>
            <a href="/ClubDePaseo?category=recomendaciones" class="category-tab @(currentCategory == "recomendaciones" ? "active" : "")">@(isPt ? "Recomendações" : isEn ? "Recommendations" : "Recomendaciones")</a>
            <a href="/ClubDePaseo?category=viajes" class="category-tab @(currentCategory == "viajes" ? "active" : "")">@(isPt ? "Viagens" : isEn ? "Travel" : "Viajes")</a>
        </div>

        @if (Model.Any())
        {
            <div class="cards-grid">
                @foreach (var entry in Model)
                {
                    <div class="card-wrap reveal">
                        @if (User.IsInRole("Admin"))
                        {
                            <a href="/ClubDePaseo/Edit/@entry.Id" class="card-edit-btn" title="@(isPt ? "Editar" : isEn ? "Edit" : "Editar")" onclick="event.stopPropagation()">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                                @(isPt ? "Editar" : isEn ? "Edit" : "Editar")
                            </a>
                        }
                        <a href="/ClubDePaseo/Detail/@entry.Slug" class="card">
                            <div class="card-img-wrap">
                                <img src="@(entry.ImagePath ?? "https://images.unsplash.com/photo-1599413987323-b2b8c0d7d9c8?w=600")" alt="@(isPt ? entry.TitlePt : isEn ? entry.TitleEn : entry.Title)" class="card-img" loading="lazy">
                            </div>
                            <div class="card-body">
                                <span class="card-tag">@(isEn ? entry.LocationNameEn ?? "Montevideo" : isPt ? entry.LocationNamePt ?? "Montevidéu" : entry.LocationName ?? "Montevideo")</span>
                                <h3 class="card-title">@(isPt ? entry.TitlePt : isEn ? entry.TitleEn : entry.Title)</h3>
                                <p class="card-text">@(isPt ? entry.ExcerptPt : isEn ? entry.ExcerptEn : entry.Excerpt)</p>
                            </div>
                            <div class="card-footer">
                                <span class="card-date">@entry.PublishDate.ToString("dd MMM yyyy")</span>
                                <span class="card-link">@(isPt ? "Ler mais" : isEn ? "Read more" : "Leer más") →</span>
                            </div>
                        </a>
                    </div>
                }
            </div>

            @if (totalPages > 1)
            {
                <div class="pagination">
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        if (i == currentPage)
                        {
                            <span class="active">@i</span>
                        }
                        else
                        {
                            <a href="/ClubDePaseo?@(string.IsNullOrEmpty(currentCategory) ? "" : $"category={currentCategory}&")page=@i">@i</a>
                        }
                    }
                </div>
            }
        }
    </div>
</section>
